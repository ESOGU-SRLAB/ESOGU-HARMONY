<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="gripper" params="
    tf_prefix
    parent
    *origin
    sim_ignition:=false
    ">

    <!-- ==================== LINKS ==================== -->

    <link name="${tf_prefix}gripper_body">
      <inertial>
        <origin xyz="-0.015094849333356525 0.0009171496638341419 0.06339132112531773" rpy="0 0 0"/>
        <mass value="4.92893092862587"/>
        <inertia ixx="0.005611" iyy="0.008" izz="0.006152" ixy="-0.0" iyz="-2.3e-05" ixz="0.0"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_body_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="violet">
          <color rgba="0.4 0.18 0.57 1.0" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_body_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${tf_prefix}gripper_upper">
      <inertial>
        <origin xyz="-0.0024097196655041425 -0.012480247735723496 0.01869961002404573" rpy="0 0 0"/>
        <mass value="0.15599517363758736"/>
        <inertia ixx="6.6e-05" iyy="4.9e-05" izz="3.3e-05" ixy="0.0" iyz="-0.0" ixz="1e-05"/>
      </inertial>
      <visual>
        <origin xyz="0.064844 -0.0135 -0.114075" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_upper_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey">
          <color rgba="0.2 0.2 0.2 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0.064844 -0.0135 -0.114075" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_upper_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${tf_prefix}gripper_lower">
      <inertial>
        <origin xyz="0.0024105236654536483 -0.012519772264191995 0.018698905548844943" rpy="0 0 0"/>
        <mass value="0.15599517363773097"/>
        <inertia ixx="6.6e-05" iyy="4.9e-05" izz="3.3e-05" ixy="0.0" iyz="0.0" ixz="-1e-05"/>
      </inertial>
      <visual>
        <origin xyz="-0.034656 -0.0135 -0.114075" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_lower_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="grey">
          <color rgba="0.2 0.2 0.2 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="-0.034656 -0.0135 -0.114075" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file:////home/cem/colcon_ws/src/gripper_test/meshes/gripper_lower_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <!-- ==================== JOINTS ==================== -->

    <!-- Gripper body to parent (fixed) -->
    <joint name="${tf_prefix}gripper_body_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${tf_prefix}gripper_body"/>
    </joint>

    <!-- Upper finger joint (primary, commanded) -->
    <joint name="${tf_prefix}gripper_joint" type="prismatic">
      <origin xyz="-0.064844 0.0135 0.114075" rpy="0 0 0"/>
      <parent link="${tf_prefix}gripper_body"/>
      <child link="${tf_prefix}gripper_upper"/>
      <axis xyz="1.0 0.0 0.0"/>
      <limit upper="0.025" lower="0.0" effort="140" velocity="0.45"/>
    </joint>

    <!-- Lower finger joint (mimic) -->
    <joint name="${tf_prefix}gripper_lower_finger_joint" type="prismatic">
      <mimic joint="${tf_prefix}gripper_joint" multiplier="-1"/>
      <origin xyz="0.034656 0.0135 0.114075" rpy="0 0 0"/>
      <parent link="${tf_prefix}gripper_body"/>
      <child link="${tf_prefix}gripper_lower"/>
      <axis xyz="1.0 0.0 0.0"/>
      <limit upper="0.0" lower="-0.025" effort="140" velocity="0.45"/>
    </joint>

    <ros2_control name="${tf_prefix}GripperControl" type="system">
      <hardware>
        <xacro:if value="${sim_ignition}">
          <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </xacro:if>
      </hardware>
      <joint name="${tf_prefix}gripper_joint">
        <command_interface name="position"/>
        <state_interface name="position">
          <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${tf_prefix}gripper_lower_finger_joint">
        <param name="mimic">${tf_prefix}gripper_joint</param>
        <param name="multiplier">-1</param>
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </ros2_control>

  </xacro:macro>

</robot>
