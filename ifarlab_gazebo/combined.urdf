      <odom_topic>odom</odom_topic>
      <!-- TF yayınla -->
      <odom_publish_frequency>50</odom_publish_frequency>
      <tf_topic>/tf</tf_topic>
      <!-- Frame isimleri: odom -> ota_base_link (world->odom static TF ile ayarlanacak) -->
      <frame_id>odom</frame_id>
      <child_frame_id>ota_base_link</child_frame_id>
    </plugin>
