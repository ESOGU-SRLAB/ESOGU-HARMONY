    <origin rpy="0 0 0" xyz="-0.37 0.22 -0.048"/>
    <child link="caster_back_left_link"/>
    <parent link="ota_base_link"/>
  </joint>
  <gazebo reference="caster_back_left_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <material>Gazebo/Red</material>
    <visual>
      <material>
        <ambient>1 0 0 1</ambient>
        <diffuse>1 0 0 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
      </material>
    </visual>
  </gazebo>
  <!-- <link name='caster_wheel_${side}_link'>
      <visual>
        <origin xyz="0 0 0"/>
        <geometry>
          <cylinder radius="0.042" length="0.02"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0"/>
        <geometry>
          <cylinder radius="0.042" length="0.02"/>
        </geometry>
      </collision>

      <xacro:cylinder_inertial radius="0.042" length="0.02" mass="0.1" />
    </link>      
    
    <joint name="caster_${side}_wheel_joint" type="fixed">
      <axis xyz="0 1 0"/>
      <origin xyz="-0.04 0 -0.07"/>
      <parent link="caster_${side}_link"/>
      <child link="caster_wheel_${side}_link"/>
    </joint>   -->
  <!-- <xacro:ota_ir base_link="${base_link}" link_name="ota_ir" xyz_ir="0.503 0.0 0.175" rpy_ir="0 0 0"/>

    
    <xacro:ota_wheel base_link="${base_link}" xyz_hub="0 -0.305 0.10" rpy_hub="0 0 0" side="left"/>
    <xacro:ota_wheel base_link="${base_link}" xyz_hub="0 0.295 0.10" rpy_hub="0 0 0" side="right"/>

    
    <xacro:ota_swivel base_link="${base_link}" xyz_caster="0.37 -0.223 0.12" rpy_caster="0 0 0" side="front_right"/>
    <xacro:ota_swivel base_link="${base_link}" xyz_caster="0.37 0.217 0.12" rpy_caster="0 0 0" side="front_left"/>
    <xacro:ota_swivel base_link="${base_link}" xyz_caster="-0.37 -0.223 0.12" rpy_caster="0 0 0" side="back_right"/>
    <xacro:ota_swivel base_link="${base_link}" xyz_caster="-0.37 0.217 0.12" rpy_caster="0 0 0" side="back_left"/> -->
  <gazebo>
    <plugin filename="libignition-gazebo6-diff-drive-system.so" name="ignition::gazebo::systems::DiffDrive">
      <!-- Tekerlek eklemleri (ota_wheel.xacro'daki joint isimleri) -->
      <left_joint>wheel_left_base</left_joint>
      <right_joint>wheel_right_base</right_joint>
      <!-- Geometri -->
      <wheel_separation>0.60</wheel_separation>
      <wheel_radius>0.102</wheel_radius>
      <!-- Hız limitleri -->
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <!-- Komut ve odom topic'leri - basit isimler (bridge ile ROS'a bağlanacak) -->
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <!-- TF yayınla -->
      <odom_publish_frequency>50</odom_publish_frequency>
      <tf_topic>/tf</tf_topic>
      <!-- Frame isimleri: odom -> ota_base_link (world->odom static TF ile ayarlanacak) -->
      <frame_id>odom</frame_id>
      <child_frame_id>ota_base_link</child_frame_id>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libignition-gazebo6-joint-state-publisher-system.so" name="ignition::gazebo::systems::JointStatePublisher">
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>
  <ros2_control name="rs005l" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <!-- orjinalinde command interface effort bunu sormak lazım -->
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint5">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  <!--
    ROS1: Bu dosya ros_control transmission tanımlarını içeriyordu.

    ROS2 Humble + Ignition:
      - "transmission_interface/SimpleTransmission" artık kullanılmıyor.
      - Joint command interface'leri ros2_control üzerinden tanımlanacak.
      - Simülasyon tarafı gz_ros2_control plugin ile world/launch içinde kurulacak.

    Bu nedenle bu xacro dosyası ROS2 versiyonunda intentionally no-op'tur.
  -->
  <!-- ROS2 Humble + Ignition:
       Gazebo Classic pluginleri artık çalışmaz.
       ros2_control, gz_ros2_control ve benzeri sistem pluginleri
       world veya launch dosyasında tanımlanmalıdır.
       Bu dosya artık intentionally no-op'tur. -->
  <!-- link rviz colors -->
  <material name="White">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="Black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="silver">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <!-- === Link 0 === -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://mobile_manipulator_description/meshes/khi_rs/RS005L_J0.STL"/>
      </geometry>
      <material name="White"/>
