  <!-- Joint tanımları -->
  <joint name="sim_ur10e_table_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="world"/>
    <child link="sim_ur10e_table"/>
  </joint>
  <!-- <joint name="${tf_prefix}base_to_chassis" type="fixed">
      <parent link="${parent}"/>
      <child link="${tf_prefix}chassis"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint> -->
  <!-- Linear axis joint - bu joint'in tam tanımı burada olmalı -->
  <joint name="sim_ur10e_base_to_robot_mount" type="prismatic">
    <parent link="sim_ur10e_table"/>
    <child link="sim_ur10e_robot_mount"/>
    <origin rpy="0 0 0" xyz="-0.158 0.115 0.58635"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit effort="1000" lower="0.05" upper="1.95" velocity="1.25"/>
    <dynamics damping="100.0" friction="50.0"/>
  </joint>
  <joint name="sim_ur10e_base_to_alumuniumtable" type="fixed">
    <parent link="world"/>
    <child link="sim_ur10e_alumunium_table"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <joint name="sim_ur10e_base_to_conveyorbelt" type="fixed">
    <parent link="world"/>
    <child link="sim_ur10e_conveyor_belt"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <!-- <joint name="${tf_prefix}base_to_walldoor" type="fixed">
      <parent link="${parent}"/>
      <child link="${tf_prefix}wall_door"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <joint name="${tf_prefix}base_to_wall_server" type="fixed">
      <parent link="${parent}"/>
      <child link="${tf_prefix}wall_server"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint> -->
  <ros2_control name="LinearAxisHardwareInterface" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="sim_ur10e_base_to_robot_mount">
      <command_interface name="position">
        <param name="min">0.05</param>
        <param name="max">1.95</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">-1.25</param>
        <param name="max">1.25</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
  <transmission name="sim_ur10e_linear_axis_transmission">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="sim_ur10e_base_to_robot_mount">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
    </joint>
    <actuator name="sim_ur10e_linear_axis_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <ros2_control name="sim_ur10e_ur10e" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="sim_ur10e_shoulder_pan_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_shoulder_lift_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">-1.57</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_elbow_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_wrist_1_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">-1.57</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_wrist_2_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_wrist_3_joint">
      <command_interface name="position"/>
      <command_interface name="velocity"/>
      <state_interface name="position">
        <!-- initial position for the FakeSystem and simulation -->
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_gripper_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0005</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sim_ur10e_gripper_lower_finger_joint">
      <param name="mimic">sim_ur10e_gripper_joint</param>
      <param name="multiplier">-1</param>
      <!-- multiplier=-1: follower moves in opposite direction to match mimic axis convention -->
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>
