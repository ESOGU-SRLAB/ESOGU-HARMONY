  <!-- RGBD camera (depth_optical_frame linkine bağlı) -->
  <gazebo reference="sim_ur10e_depth_optical_frame">
    <sensor name="sim_ur10e_rgbd_camera" type="rgbd_camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>
      <camera name="sim_ur10e_rgbd">
        <horizontal_fov>1.22</horizontal_fov>
        <image>
          <width>512</width>
          <height>424</height>
          <format>R8G8B8</format>
        </image>
        <depth_image>
          <width>512</width>
          <height>424</height>
          <format>R_FLOAT32</format>
        </depth_image>
        <clip>
          <near>0.05</near>
          <far>16.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  <!-- IMX179 RGB camera (IMX_Camera linkine bağlı) -->
  <gazebo reference="sim_ur10e_IMX_Camera">
    <sensor name="sim_ur10e_imx179_camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>
      <camera name="sim_ur10e_imx179_rgb">
        <!-- 145 deg = 2.5307 rad -->
        <horizontal_fov>2.5307</horizontal_fov>
        <image>
          <width>3288</width>
          <height>2512</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>16.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
